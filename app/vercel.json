{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/ultron-backend.cjs" }
  ],
  "functions": {
    "server/ultron-backend.cjs": {
      "runtime": "nodejs20.x"
    }
  }
}
