      "permission": "READ_ONLY"
    },
    {
      "id": "repo_file_scan_limited",
      "label": "Limited Repo File Scan",
      "type": "builtin",
      "operation": "limited_file_scan",
      "working_directory": "/Users/macbook/ultron",
      "risk": "LOW",
      "permission": "READ_ONLY"
    },
    {
      "id": "git_status_review",
      "label": "Git Status Review",
      "type": "execFile",
      "executable": "git",
      "args": ["status", "--short"],
      "working_directory": "/Users/macbook/ultron",
      "risk": "LOW",
      "permission": "READ_ONLY"
    },
    {
      "id": "git_log_review",
      "label": "Git Log Review",
      "type": "execFile",
      "executable": "git",
      "args": ["log", "--oneline", "-5"],
      "working_directory": "/Users/macbook/ultron",
      "risk": "LOW",
      "permission": "READ_ONLY"
    },
    {
      "id": "git_diff_stat_review",
      "label": "Git Diff Stat Review",
      "type": "execFile",
      "executable": "git",
      "args": ["diff", "--stat"],
      "working_directory": "/Users/macbook/ultron",
      "risk": "LOW",
      "permission": "READ_ONLY"
    },
    {
      "id": "app_build_check",
      "label": "App Build Check",
