{
  "project": "ULTRON",
  "version": "v1.5",
  "mode": "SUPERVISED_AUTONOMY",
  "backend": {
    "type": "node_http_native",
    "port": 3001,
    "token": "ULTRON_LOCAL_OPERATOR_TOKEN",
    "healthEndpoint": "/api/health",
    "chatEndpoint": "/api/chat",
    "status": "READY_FOR_VERCEL_SECURE_ENVIRONMENT"
  },
  "aiProvider": {
    "default": "openai",
    "supported": ["openai", "claude"],
    "selectionSource": "AI_PROVIDER"
  },
  "aiProxy": {
    "status": "WAITING_FOR_VERCEL_ENV",
    "secretSource": "vercel_environment_variable",
    "secretNames": ["OPENAI_API_KEY", "ANTHROPIC_API_KEY"],
    "exposeSecrets": false,
    "models": {
      "openai": "gpt-4o-mini",
      "claude": "claude-sonnet-4-5"
    }
  },
  "guardrails": {
    "realShellExecution": false,
    "gitPush": false,
    "envAccessFromUI": false,
    "autonomousAgents": false,
    "humanApprovalRequired": true
  },
  "execution": {
    "mode": "DRY_RUN_ONLY",
    "real_shell_execution": false,
    "runner_connection": false,
    "human_approval_required": true
  },
  "security": {
    "external_network": "CONTROLLED_CHAT_ONLY_AFTER_PROVIDER_KEY",
    "secrets_access": false,
    "env_access": false,
    "git_push": false,
    "autonomous_execution": false
  },
  "memory": {
    "whitelist": [
      "operator_command_log.md",
      "v1_1_real_operator_testing_snapshot.json",
      "runtime_config.json"
    ]
  },
  "status": "ULTRON_V1_5_READY_FOR_VERCEL_ENV_AND_MOBILE_LIVE_TEST"
}
